#!/usr/bin/env bash
set -euo pipefail

target="${1:-}"
channel="${2:-}"
source_branch="${3:-}"
run_attempt="${4:-}"

workspace_root="${MOON_WORKSPACE_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
cd "${workspace_root}"

if [[ -z "${target}" || -z "${channel}" || -z "${source_branch}" || -z "${run_attempt}" ]]; then
  echo "ERROR: usage: $0 <target> <next|latest> <main|release/*> <run-attempt>" >&2
  exit 1
fi

case "${channel}" in latest|next) ;; *) echo "ERROR: unsupported channel '${channel}'." >&2; exit 1 ;; esac
case "${source_branch}" in main|release/*) ;; *) echo "ERROR: unsupported source branch '${source_branch}'." >&2; exit 1 ;; esac
[[ "${run_attempt}" =~ ^[1-9][0-9]*$ ]] || { echo "ERROR: run-attempt must be a positive integer." >&2; exit 1; }

projects_json="$(moon query projects)"
project_json="$(jq -ce --arg target "${target}" '.projects[] | select(.id == $target)' <<<"${projects_json}")" || {
  echo "ERROR: unknown Moon target '${target}'." >&2
  exit 1
}

jq -e '(.tasks // {}) | has("publish")' >/dev/null <<<"${project_json}" || {
  echo "ERROR: Moon target '${target}' is not publishable." >&2
  exit 1
}

source="$(jq -r '.source // ""' <<<"${project_json}")"
[[ -n "${source}" ]] || { echo "ERROR: Moon target '${target}' has no source path." >&2; exit 1; }

if [[ -f "${source}/package.json" ]]; then
  current_version="$(jq -r '.version // ""' "${source}/package.json")"
elif [[ -f "${source}/Cargo.toml" ]]; then
  current_version="$(cargo metadata --no-deps --format-version 1 --manifest-path "${source}/Cargo.toml" | jq -r --arg manifest "$(cd "${source}" && pwd -P)/Cargo.toml" '.packages[] | select(.manifest_path == $manifest) | .version')"
else
  echo "ERROR: unsupported version source for '${source}'." >&2
  exit 1
fi

is_semver() {
  local value="${1}"
  local semver_re='^(0|[1-9][0-9]*)\.(0|[1-9][0-9]*)\.(0|[1-9][0-9]*)(-([0-9A-Za-z-]+)(\.[0-9A-Za-z-]+)*)?(\+([0-9A-Za-z-]+)(\.[0-9A-Za-z-]+)*)?$'
  [[ "${value}" =~ ${semver_re} ]] || return 1

  local prerelease=""
  [[ "${value}" == *-* ]] && prerelease="${value#*-}" && prerelease="${prerelease%%+*}"
  local identifier
  IFS=. read -ra identifiers <<<"${prerelease}"
  for identifier in "${identifiers[@]}"; do
    [[ "${identifier}" =~ ^[0-9]+$ && "${identifier}" != 0 && "${identifier}" == 0* ]] && return 1
  done
}

is_semver "${current_version}" || { echo "ERROR: malformed semantic version '${current_version}' for '${target}'." >&2; exit 1; }

base_version="${current_version%%[-+]*}"
IFS=. read -r major minor patch <<<"${base_version}"
[[ "${source}" == "." ]] && tag_prefix="v" || tag_prefix="${source}-v"
stable_tag=""
while IFS= read -r candidate_tag; do
  candidate_version="${candidate_tag#"${tag_prefix}"}"
  if [[ "${candidate_version}" =~ ^(0|[1-9][0-9]*)\.(0|[1-9][0-9]*)\.(0|[1-9][0-9]*)$ ]]; then
    stable_tag="${candidate_tag}"
    break
  fi
done < <(git tag --merged HEAD --list "${tag_prefix}*" --sort=-v:refname)

if [[ -n "${stable_tag}" ]]; then
  commit_distance="$(git rev-list --first-parent --count "${stable_tag}..HEAD")"
else
  commit_distance="$(git rev-list --first-parent --count HEAD)"
fi

version="${current_version}"
if [[ "${channel}" == next ]]; then
  if [[ "${source_branch}" == main ]]; then
    minor=$((minor + 1)); patch=0
  else
    patch=$((patch + 1))
  fi
  version="${major}.${minor}.${patch}-next.${commit_distance}.${run_attempt}"
fi

release_tag="${tag_prefix}${version}"
jq -nc \
  --arg target "${target}" \
  --arg source "${source}" \
  --arg current_version "${current_version}" \
  --arg stable_tag "${stable_tag}" \
  --argjson commit_distance "${commit_distance}" \
  --arg version "${version}" \
  --arg release_tag "${release_tag}" \
  '{target:$target,source:$source,current_version:$current_version,stable_tag:$stable_tag,commit_distance:$commit_distance,version:$version,release_tag:$release_tag}'
