#!/usr/bin/env bash
set -euo pipefail

publish_channel="${PUBLISH_CHANNEL:-}"
if [ -z "${publish_channel}" ]; then
  echo "ERROR: PUBLISH_CHANNEL is required (expected: latest or next)." >&2
  exit 1
fi

case "${publish_channel}" in latest|next) ;; *) echo "ERROR: unsupported PUBLISH_CHANNEL '${publish_channel}'." >&2; exit 1 ;; esac

if [ "${publish_channel}" = "next" ]; then
  : "${PUBLISH_VERSION:?PUBLISH_VERSION is required for next publishing}"
  echo "Preparing next prerelease: ${PUBLISH_VERSION}"
  node -e '
    const fs = require("node:fs");
    const pkgPath = "package.json";
    const pkg = JSON.parse(fs.readFileSync(pkgPath, "utf8"));
    pkg.version = process.argv[1];
    fs.writeFileSync(pkgPath, `${JSON.stringify(pkg, null, 2)}\n`);
  ' "${PUBLISH_VERSION}"
fi

args=(--access public --tag "${publish_channel}")
# if [ -n "${GITHUB_ACTIONS:-}" ]; then
# args+=(--provenance)
# fi
#
echo "> npm publish ${args[*]}"

npm publish "${args[@]}"
