layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="tab-bar"
        }
        pane split_direction="vertical" {
            pane size=48 borderless=true {
                plugin location="file:target/wasm32-wasip1/release/zellij-plugin-agent-threads.wasm" {
                    // Replace with `readlink -f /path/to/main.jinja`.
                    template_file "/absolute/path/to/custom-template/main.jinja"
                }
            }
            pane {
                children
            }
        }
    }

    new_tab_template {
        pane size=1 borderless=true {
            plugin location="tab-bar"
        }
        pane split_direction="vertical" {
            pane size=48 borderless=true {
                plugin location="file:target/wasm32-wasip1/release/zellij-plugin-agent-threads.wasm" {
                    // Replace with `readlink -f /path/to/main.jinja`.
                    template_file "/absolute/path/to/custom-template/main.jinja"
                }
            }
            pane {
                children
            }
        }
    }
}

session_serialization false
