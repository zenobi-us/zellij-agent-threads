    },
    "pkgs/provider-gpu": {
      "group": "provider",
      "release-type": "node"
    },
    "pkgs/provider-link": {
      "group": "provider",
      "release-type": "node"
    },
    "pkgs/provider-network": {
      "group": "provider",
      "release-type": "node"
    },
    "pkgs/provider-os": {
      "group": "provider",
