#!/usr/bin/env bash
#MISE description="Start Zellij dev layout"
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
WASM_NAME="zellij-plugin-agent-worktree-list.wasm"
WASM_SRC="$ROOT/target/wasm32-wasip1/release/$WASM_NAME"
ZELLIJ_PLUGIN_DIR="$HOME/.config/zellij/plugins"
PI_EXTENSION_DIR="$HOME/.pi/agent/extensions"

mkdir -p "$ZELLIJ_PLUGIN_DIR" "$PI_EXTENSION_DIR"
ln -sfn "$WASM_SRC" "$ZELLIJ_PLUGIN_DIR/$WASM_NAME"
ln -sfn "$ROOT/pi-zellij-agent.ts" "$PI_EXTENSION_DIR/zellij-agent.ts"

exec zellij --layout "$ROOT/layouts/dev.kdl"
