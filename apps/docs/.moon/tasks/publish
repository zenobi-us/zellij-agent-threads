#!/usr/bin/env bash
set -euo pipefail

log() {
  printf '\033[36m[docs:publish]\033[0m %s\n' "$*" >&2
}

warn() {
  printf '\033[33m[docs:publish:warn]\033[0m %s\n' "$*" >&2
}

fail() {
  local message="${1:-unknown failure}"
  local exit_code="${2:-1}"
  printf '\033[31m[docs:publish:fail]\033[0m %s\n' "${message}" >&2
  exit "${exit_code}"
}

on_error() {
  local exit_code=$?
  fail "failed at line ${BASH_LINENO[0]} with exit code ${exit_code}" "${exit_code}"
}
trap on_error ERR

repo_name="boxfiles.github.io"
src="${MOON_PROJECT_ROOT}/dist/public"
branch="main"
tmp="$(mktemp -d)"
clone_dir="${tmp}/repo"

cleanup() {
  log "cleaning up temp dir ${tmp}"
  rm -rf "${tmp}"
}
trap cleanup EXIT

git_name="${GIT_AUTHOR_NAME:-github-actions[bot]}"
git_email="${GIT_AUTHOR_EMAIL:-41898282+github-actions[bot]@users.noreply.github.com}"
token="${DOCS_PUBLISH_TOKEN:-}"
ssh_key="${DOCS_PUBLISH_SSH_KEY:-}"
ssh_auth_sock="${SSH_AUTH_SOCK:-/tmp/docs_publish_ssh_agent.sock}"

if [ -n "${token}" ]; then
  export GH_TOKEN="${token}"
fi

log "starting docs publish"
log "source dir: ${src}"
log "target repo name: ${repo_name}"
log "target branch: ${branch}"

if [ ! -d "${src}" ]; then
  fail "source dir missing: ${src}"
fi

# Resolve the GitHub owner from CI first, then from the current repo.
owner="${GITHUB_REPOSITORY_OWNER:-}"
if [ -z "${owner}" ]; then
  warn "GITHUB_REPOSITORY_OWNER empty; resolving owner with gh"
  owner="$(gh repo view --json owner --jq .owner.login)"
fi
repo="${owner}/${repo_name}"
log "target repo: ${repo}"

clone_url="https://github.com/${repo}.git"
if [ -n "${ssh_key}" ]; then
  log "SSH key found; configuring git over SSH"
  mkdir -p "${HOME}/.ssh"
  chmod 700 "${HOME}/.ssh"
  ssh-keyscan github.com >> "${HOME}/.ssh/known_hosts"
  key_file="${tmp}/docs_publish_key"
  printf '%s\n' "${ssh_key}" > "${key_file}"
  chmod 600 "${key_file}"
  ssh-agent -a "${ssh_auth_sock}" >/dev/null
  SSH_AUTH_SOCK="${ssh_auth_sock}" ssh-add "${key_file}"
  export SSH_AUTH_SOCK="${ssh_auth_sock}"
  clone_url="git@github.com:${repo}.git"
elif [ -n "${token}" ]; then
  log "token found; configuring git over HTTPS"
  clone_url="https://x-access-token:${token}@github.com/${repo}.git"
else
  warn "no DOCS_PUBLISH_SSH_KEY or DOCS_PUBLISH_TOKEN found; git push may fail"
fi

# Create the Pages repo when token auth can do it. SSH deploy keys cannot create repos.
if git ls-remote "${clone_url}" >/dev/null 2>&1; then
  log "target repo exists"
elif [ -n "${token}" ]; then
  log "target repo missing; creating ${repo}"
  gh repo create "${repo}" --public --description "Boxfiles documentation site"
  log "target repo created"
else
  fail "target repo missing or inaccessible: ${repo}. Create it first, add its deploy key, or set DOCS_PUBLISH_TOKEN."
fi

# Clone the Pages repo into a throwaway folder so the source checkout stays untouched.
log "cloning target repo into temp dir"
git clone "${clone_url}" "${clone_dir}"
log "clone complete"

# Configure identity in the cloned repo because commits happen there, not here.
log "configuring git identity in temp clone"
git -C "${clone_dir}" config user.name "${git_name}"
git -C "${clone_dir}" config user.email "${git_email}"

# Origin already carries either SSH or HTTPS auth from clone_url.

# Publish from the root of main, even when the repo was just created empty.
if git -C "${clone_dir}" rev-parse --verify HEAD >/dev/null 2>&1; then
  log "target repo has commits; switching to ${branch}"
  git -C "${clone_dir}" switch "${branch}" 2>/dev/null || git -C "${clone_dir}" switch -C "${branch}"
else
  log "target repo is empty; creating orphan ${branch}"
  git -C "${clone_dir}" switch --orphan "${branch}"
fi

# Replace everything in the Pages repo root with the freshly built static site.
log "replacing target repo root with docs build output"
find "${clone_dir}" -mindepth 1 -maxdepth 1 ! -name .git -exec rm -rf {} +
cp -R "${src}"/. "${clone_dir}"/

# Keep GitHub Pages from running Jekyll over the generated files.
touch "${clone_dir}/.nojekyll"

# Commit and push only when the generated site changed.
log "staging generated files"
git -C "${clone_dir}" add -A
if git -C "${clone_dir}" diff --cached --quiet; then
  log "no docs changes to publish"
else
  log "committing docs changes"
  git -C "${clone_dir}" commit -m "publish docs"
  log "pushing docs to ${repo}:${branch}"
  git -C "${clone_dir}" push origin "HEAD:${branch}"
  log "push complete"
fi

# Configure GitHub Pages to serve from the repo root on main when API auth is available.
if [ -n "${token}" ]; then
  log "configuring GitHub Pages source: ${branch} /"
  if gh api "repos/${repo}/pages" >/dev/null 2>&1; then
    log "Pages site exists; updating source"
    gh api --method PUT "repos/${repo}/pages" -f "source[branch]=${branch}" -f 'source[path]=/' >/dev/null
  else
    log "Pages site missing; creating site"
    gh api --method POST "repos/${repo}/pages" -f "source[branch]=${branch}" -f 'source[path]=/' >/dev/null
  fi
  log "GitHub Pages configured"
else
  warn "skipping GitHub Pages API config; set DOCS_PUBLISH_TOKEN if Pages is not already configured"
fi
log "docs publish complete"
