# Proto toolchain config (project-local)
# Keep in sync with .moon/toolchains.yml.

bun = "1.3.14"
rust = "stable"
worktrunk = "0.62.0"
bats = "1.13.0"
trufflehog = "3.95.5"

[settings]
detect-strategy = "only-prototools"
auto-install = true
builtin-plugins = ["bun", "rust"]

[plugins.tools]
trufflehog = "file://./proto/plugins/trufflehog.toml"
worktrunk = "file://./proto/plugins/worktrunk.toml"
bats = "file://./proto/plugins/bats.toml"
