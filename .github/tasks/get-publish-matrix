#!/usr/bin/env bash

# Build publish matrix from moon affected projects.
# release-please payload is validated here; release.yml owns channel selection.

set -euo pipefail

require_payload() {
  local payload="${1:-}"

  if [[ -z "${payload}" ]]; then
    echo "Missing JSON payload argument" >&2
    exit 1
  fi

  if ! jq -e . >/dev/null 2>&1 <<<"${payload}"; then
    echo "Invalid JSON payload passed as argv[0]" >&2
    exit 1
  fi
}
resolve_payload_arg() {
  local payload_arg="${1:-}"

  if [[ "${payload_arg}" == @* ]]; then
    local payload_file="${payload_arg#@}"

    if [[ -z "${payload_file}" || ! -f "${payload_file}" ]]; then
      echo "Missing payload file: ${payload_file}" >&2
      exit 1
    fi

    cat "${payload_file}"
    return 0
  fi

  printf '%s' "${payload_arg}"
}

require_ref() {
  local value="${1:-}"
  local name="${2:-ref}"

  if [[ -z "${value}" ]]; then
    echo "Missing ${name} argument" >&2
    exit 1
  fi
}

main() {
  local payload_arg="${1:-}"
  local base="${2:-}"
  local head="${3:-}"
  local payload

  payload="$(resolve_payload_arg "${payload_arg}")"
  require_payload "${payload}"
  require_ref "${base}" "base"
  require_ref "${head}" "head"

  local affected_json
  affected_json="$(MOON_BASE="${base}" MOON_HEAD="${head}" moon query projects --affected)"
  local affected_file
  affected_file="$(mktemp)"
  trap 'rm -f "${affected_file:-}"' EXIT

  printf '%s' "${affected_json}" >"${affected_file}"
  jq -cn \
    --slurpfile affected "${affected_file}" '
      [
        (($affected[0].projects // [])[])
        | select(( (.tasks // {}) | has("publish") ))
        | { target: .id }
      ]
      | sort_by(.target)
    '
}

main "$@"
