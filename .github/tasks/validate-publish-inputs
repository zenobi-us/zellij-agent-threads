#!/usr/bin/env bash
set -euo pipefail

event_name="${1:-}"
target="${2:-}"
channel="${3:-}"
source_sha="${4:-}"
source_branch="${5:-}"
dispatch_actor="${6:-}"
trusted_actors="${7:-}"
old_tag="${8:-}"

[[ "${event_name}" == workflow_dispatch || "${event_name}" == repository_dispatch ]] || {
  echo "ERROR: unsupported trigger '${event_name}'" >&2
  exit 1
}
[[ -n "${target}" ]] || { echo "ERROR: empty publish target" >&2; exit 1; }
[[ "${channel}" == next || "${channel}" == latest ]] || { echo "ERROR: invalid channel '${channel}'" >&2; exit 1; }
[[ "${source_sha}" =~ ^[0-9a-fA-F]{40}$ ]] || { echo "ERROR: invalid source SHA '${source_sha}'" >&2; exit 1; }
case "${source_branch}" in main|release/*) ;; *) echo "ERROR: untrusted source branch '${source_branch}'" >&2; exit 1 ;; esac

if [[ "${event_name}" == repository_dispatch ]]; then
  [[ -z "${old_tag}" ]] || { echo "ERROR: obsolete client_payload.tag is forbidden" >&2; exit 1; }
  [[ -n "${trusted_actors}" ]] || { echo "ERROR: trusted dispatch actor allowlist is empty" >&2; exit 1; }

  trusted=false
  IFS=',' read -ra actors <<<"${trusted_actors}"
  for actor in "${actors[@]}"; do
    [[ "${dispatch_actor}" == "${actor}" ]] && trusted=true
  done
  [[ "${trusted}" == true ]] || { echo "ERROR: untrusted repository_dispatch actor '${dispatch_actor}'" >&2; exit 1; }
fi

jq -nc \
  --arg target "${target}" \
  --arg channel "${channel}" \
  --arg source_sha "${source_sha}" \
  --arg source_branch "${source_branch}" \
  '{target:$target,channel:$channel,source_sha:$source_sha,source_branch:$source_branch}'
